// dlide_editor.ft — datalog IDE: the query editor pane.
//
// One of a set of communicating widgets (editor / results / schema /
// history) that talk over the widget message bus (emit / on_message,
// project-scoped, SEPARATE from the Claude bus). The editor owns the
// query text and broadcasts it; it never runs queries itself.
//
//   emits:   sql.run {sql}            (Run / Cmd+Enter)
//   listens: sql.set_editor {sql}     (history: load a past query)
//            sql.use_table {table}    (schema: prefill a browse)
//            sql.result {ok,summary}  (results: show last status)
//            conn.state {host}        (retained: current DB host)
import "host"

fn init_state() = { sql: "", host: "127.0.0.1:5557", status: "" }
let state = atom(init_state())

fn on_input_change(id, value) {
    if id == "sql" {
        reset!(state, { ..(@state), sql: value })
        request_render()
    }
}

fn on_input_submit(id, value) {        // Cmd/Ctrl+Enter in the textarea
    if id == "sql" {
        reset!(state, { ..(@state), sql: value })
        emit("sql.run", { sql: value })
        request_render()
    }
}

fn on_click(x, y, shift, cmd, id) {
    if id == "run" { emit("sql.run", { sql: (@state).sql }); return }
    if id == "clear" { reset!(state, { ..(@state), sql: "" }); request_render(); return }
    if id == "ex_schema" {
        reset!(state, { ..(@state), sql: "schema" })
        emit("sql.run", { sql: "schema" })
        request_render()
        return
    }
}

fn on_message(topic, payload, sender) {
    if sender == my_id() { return }
    if topic == "sql.set_editor" {
        reset!(state, { ..(@state), sql: payload.sql })
        host_log("[dlide_editor] set_editor: " + payload.sql)
        request_render()
    } else if topic == "sql.use_table" {
        reset!(state, { ..(@state), sql: "list " + payload.table + " limit 50" })
        host_log("[dlide_editor] use_table: " + payload.table)
        request_render()
    } else if topic == "conn.state" {
        reset!(state, { ..(@state), host: payload.host })
        request_render()
    } else if topic == "sql.result" {
        let st = if payload.ok { "ok · " + payload.summary } else { "error · " + payload.summary }
        reset!(state, { ..(@state), status: st })
        request_render()
    }
}

// Re-render on pane resize so layout (e.g. table widths) tracks the
// new canvas size — render() depends on `w`/`h`.
fn on_resize(w, h) { request_render() }

fn render(w, h) {
    let s = @state
    let status_color = if s.status.starts_with("error") { "#e0746f" }
                       else if s.status.starts_with("ok") { "#6cc08a" }
                       else { "fg_muted" }

    {
        kind: "vstack", gap: 8.0,
        style: { background: "surface_1", width: "100%", height: "100%",
                 padding: { top: 10.0, right: 12.0, bottom: 12.0, left: 12.0 } },
        children: [
            // editor surface fills available height
            {
                kind: "frame", pad: 8.0, gap: 0.0,
                style: { background: "surface_2", radius: "radius_md", flex_grow: 1.0, width: "100%",
                         border: { color: "surface_3", width: 1.0 } },
                children: [
                    // Fills the card both ways now: editor-idea fixed the layout to
                    // pass the known pane height (content_size.y) as available, so
                    // flex_grow + height:"100%" resolve vertically too.
                    {
                        kind: "textarea", id: "sql", value: s.sql, rows: 3,
                        style: { background: "surface_2", width: "100%", height: "100%", flex_grow: 1.0 },
                        placeholder: "find ?n, ?age where ?u: User { name: ?n, age: ?age }   (Cmd+Enter to run)\nlist · schema · assert · define · drop · purge all work",
                    },
                ],
            },
            // toolbar: primary Run + secondary actions, status on the right
            {
                kind: "hstack", gap: 6.0, align: "center", children: [
                    { kind: "button", id: "run", label: "Run  ⌘↵" },
                    { kind: "button", id: "clear", label: "Clear" },
                    { kind: "button", id: "ex_schema", label: "schema" },
                    { kind: "text", value: "   " + s.status, size: 11.0, color: status_color },
                ],
            },
        ],
    }
}
